{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StaffWeekCalendarResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["week_start", "week_end", "timezone", "results"],
  "properties": {
    "week_start": {"type": "string", "format": "date"},
    "week_end": {"type": "string", "format": "date"},
    "timezone": {"type": "string"},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id","course_id","course_title","class_id","class_name","teacher_id","teacher_name","start_at","end_at","status","event_title","class_detail_url"],
        "properties": {
          "event_id": {"type": "string"},
          "course_id": {"type": "string"},
          "course_title": {"type": "string"},
          "class_id": {"type": "string"},
          "class_name": {"type": "string"},
          "teacher_id": {"type": "integer"},
          "teacher_name": {"type": "string"},
          "start_at": {"type": "string", "format": "date-time"},
          "end_at": {"type": "string", "format": "date-time"},
          "status": {"type": "string", "enum": ["scheduled", "not_scheduled", "event_only"]},
          "event_title": {"type": "string"},
          "class_detail_url": {"type": "string"}
        }
      }
    }
  }
}
